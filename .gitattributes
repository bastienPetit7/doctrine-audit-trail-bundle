# Normalize line endings on checkin.
* text=auto eol=lf

# Force binary handling for common binary assets (defensive).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  binary

# ---------------------------------------------------------------------------
# Exclude development-only files from the `composer require` dist tarball.
# These are useful in the Git repository but should not bloat installs.
# ---------------------------------------------------------------------------

/.github                  export-ignore
/tests                    export-ignore
/var                      export-ignore

/.gitattributes           export-ignore
/.gitignore               export-ignore
/.php-cs-fixer.dist.php   export-ignore
/.php-cs-fixer.cache      export-ignore
/phpstan.dist.neon        export-ignore
/phpstan-baseline.neon    export-ignore
/phpunit.xml.dist         export-ignore

/CONTRIBUTING.md          export-ignore

# Diff hints for review readability.
*.php   diff=php
*.md    diff=markdown
