{
    "name": "metadev/doctrine-audit-trail-bundle",
    "description": "Doctrine audit trail bundle for Symfony: tracks entity mutations with user attribution, IP, and JSON diffs — GDPR-ready and built for production.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["symfony", "symfony-bundle", "doctrine", "audit", "audit-trail", "audit-log", "gdpr", "history", "logging"],
    "homepage": "https://github.com/bastienPetit7/doctrine-audit-trail-bundle",
    "authors": [
        {
            "name": "Bastien Petit",
            "email": "bastien.petit7@gmail.com",
            "homepage": "https://github.com/bastienPetit7",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/bastienPetit7/doctrine-audit-trail-bundle/issues",
        "source": "https://github.com/bastienPetit7/doctrine-audit-trail-bundle",
        "docs": "https://github.com/bastienPetit7/doctrine-audit-trail-bundle#readme"
    },
    "require": {
        "php": ">=8.2",
        "doctrine/doctrine-bundle": "^2.10|^3.0",
        "doctrine/orm": "^2.14|^3.0",
        "symfony/config": "^6.4|^7.0|^8.0",
        "symfony/console": "^6.4|^7.0|^8.0",
        "symfony/dependency-injection": "^6.4|^7.0|^8.0",
        "symfony/http-kernel": "^6.4|^7.0|^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.50",
        "matthiasnoback/symfony-dependency-injection-test": "^6.3",
        "nyholm/symfony-bundle-test": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^11.0",
        "symfony/framework-bundle": "^6.4|^7.0|^8.0",
        "symfony/http-foundation": "^6.4|^7.0|^8.0",
        "symfony/messenger": "^6.4|^7.0|^8.0",
        "symfony/security-core": "^6.4|^7.0|^8.0"
    },
    "suggest": {
        "symfony/security-core": "To attribute audit entries to the authenticated user",
        "symfony/http-foundation": "To capture the client IP address and user agent",
        "symfony/messenger": "To offload audit persistence with persistence.mode: async",
        "doctrine/migrations": "To version the audit schema, including the optional integrity 'signature' column"
    },
    "autoload": {
        "psr-4": {
            "Metadev\\DoctrineAuditTrailBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Metadev\\DoctrineAuditTrailBundle\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-unit": "vendor/bin/phpunit --testsuite=unit",
        "test-integration": "vendor/bin/phpunit --testsuite=integration",
        "test-functional": "vendor/bin/phpunit --testsuite=functional",
        "cs-fix": "vendor/bin/php-cs-fixer fix",
        "cs-check": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "phpstan": "vendor/bin/phpstan analyse --configuration=phpstan.dist.neon --memory-limit=512M",
        "ci": [
            "@cs-check",
            "@phpstan",
            "@test"
        ]
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
